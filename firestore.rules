rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Users can read/write their own profile.
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Admin list: only admins can manage this collection.
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Menu is publicly readable; only admins can modify.
    match /menu/{menuId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Orders: users can create their own orders; users can read their own orders; admins can manage all.
    match /orders/{orderId} {
      function validOrder() {
        return request.resource.data.keys().hasAll(["userId", "userEmail", "items", "subtotal", "deliveryFee", "total", "paymentStatus", "orderStatus", "createdAt"])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.items.size() > 0
          && request.resource.data.total > 0
          && request.resource.data.total == request.resource.data.subtotal + request.resource.data.deliveryFee
          // Non-admins MUST create orders as unpaid and pending
          && (isAdmin() || (
              request.resource.data.paymentStatus == "unpaid" && 
              request.resource.data.orderStatus == "pending"
          ));
      }

      allow create: if isAdmin() || (isSignedIn() && validOrder());
      allow read: if resource.data.userId == request.auth.uid || isAdmin();
      
      // Users can only push "no-op" background syncs without altering existing data. Admins can update fully.
      allow update: if isAdmin() || (
        isOwner(resource.data.userId) &&
        request.resource.data.diff(resource.data).affectedKeys().size() == 0
      );
      allow delete: if isAdmin();
    }
  }
}
